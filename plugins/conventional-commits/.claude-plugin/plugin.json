{
  "name": "conventional-commits",
  "description": "Conventional commit message rules and tooling setup for commitlint + husky",
  "version": "1.0.0",
  "author": {
    "name": "Daniel Barta",
    "email": "barta.daniel@gmail.com"
  },
  "homepage": "https://github.com/bartadaniel/claude-plugins/tree/main/plugins/conventional-commits",
  "repository": "https://github.com/bartadaniel/claude-plugins",
  "license": "MIT",
  "keywords": ["conventional-commits", "commitlint", "husky", "git-hooks", "commit-messages"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PLUGIN_ROOT}/rules.md\""
          }
        ]
      }
    ]
  }
}
