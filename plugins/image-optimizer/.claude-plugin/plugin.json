{
  "name": "image-optimizer",
  "description": "Automatically downsize and compress images from MCP tools to reduce session size",
  "version": "1.0.0",
  "author": {
    "name": "Daniel Barta",
    "email": "barta.daniel@gmail.com"
  },
  "homepage": "https://github.com/bartadaniel/claude-plugins/tree/main/plugins/image-optimizer",
  "repository": "https://github.com/bartadaniel/claude-plugins",
  "license": "MIT",
  "keywords": ["image", "optimize", "compress", "resize", "mcp", "jpeg"],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/optimize-image.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
