{
  "chrome-devtools": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "chrome-devtools-mcp@latest",
      "--browserUrl=http://localhost:9222",
      "--experimental-screencast=true",
      "--usageStatistics=false"
    ],
    "env": {}
  },
  "next-devtools": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "next-devtools-mcp@latest"
    ],
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  }
}
